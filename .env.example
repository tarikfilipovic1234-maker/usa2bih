# ─────────────────────────────────────────────────────────────
# USA2BIH — Environment variables
# Copy this file to `.env.local` and fill in real values.
# ─────────────────────────────────────────────────────────────

# Public site URL (used for SEO, OG images, absolute links)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Neon PostgreSQL ──────────────────────────────────────────
# Pooled connection (used by the app at runtime on serverless).
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
# Direct (unpooled) connection — required by Prisma Migrate.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# ── Neon Auth (Better Auth) ──────────────────────────────────
# Neon Console → Auth tab → Configuration → "Auth URL".
NEON_AUTH_BASE_URL=""
# Signs session cookies; generate with: openssl rand -base64 32  (>=32 chars)
NEON_AUTH_COOKIE_SECRET=""

# ── Vercel Blob (vehicle images, documents) ──────────────────
BLOB_READ_WRITE_TOKEN=""

# ── Resend (transactional email) ─────────────────────────────
RESEND_API_KEY=""
# Address that contact/inquiry notifications are sent to + from.
EMAIL_FROM="USA2BIH <noreply@usa2bih.com>"
EMAIL_TO="info@usa2bih.com"

# ── Admin allowlist ──────────────────────────────────────────
# Comma-separated emails auto-promoted to ADMIN on profile sync.
ADMIN_EMAILS="tarikfilipovic1234@gmail.com"
